#! /bin/sh

### BEGIN INIT INFO
# Provides:          ollama
# Required-Start:    $network $remote_fs $syslog
# Required-Stop:     $network $remote_fs $syslog
# Default-Start:     2 3 4 5
# Default-Stop:
# Short-Description: Ollama Serve Daemon
### END INIT INFO

set -e

PATH="/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"

NAME="ollama"
DAEMON="$(command -v ollama || echo /usr/local/bin/ollama)"
PIDFILE="/run/ollama.pid"
LOGFILE="/var/log/ollama.log"
ENV_HOST="0.0.0.0:11434"

. /lib/lsb/init-functions

export OLLAMA_HOST="$ENV_HOST"

start() {
    log_daemon_msg "Starting Ollama" "$NAME"

    start-stop-daemon --start --background --make-pidfile \
        --chuid ubuntu:ubuntu \
        --pidfile "$PIDFILE" \
        --exec /bin/sh -- -c "
        export HOME=/home/ubuntu
        OLLAMA_HOST=$ENV_HOST
        ollama serve >> $LOGFILE 2>&1
        "

    log_end_msg $?
}

stop() {
    log_daemon_msg "Stopping Ollama" "$NAME"
    start-stop-daemon --stop --quiet --pidfile "$PIDFILE" --retry 30 || true
    rm -f "$PIDFILE"
    log_end_msg $?
}

restart() {
    stop
    start
}

status() {
    if [ -f "$PIDFILE" ] && kill -0 "$(cat $PIDFILE)" 2>/dev/null; then
        echo "Ollama is running"
        exit 0
    else
        echo "Ollama is not running"
        exit 1
    fi
}

case "$1" in
    start) start ;;
    stop) stop ;;
    restart) restart ;;
    status) status ;;
    *) echo "Usage: $0 {start|stop|restart|status}" ; exit 1 ;;
esac

exit 0